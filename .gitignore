# Runtime action-registry cache, regenerated by the daemon.
.actions.tmp.json

# Claude Code local/runtime state (shareable .claude/ config stays tracked).
.claude/worktrees/
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Brainstorming visual-companion artifacts
.superpowers/

# Internal design scratch (plans + specs), not user-facing documentation.
docs/superpowers/

# Runtime allowlist — copied from config/allowlist.default.json on first daemon
