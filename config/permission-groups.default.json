{
  "core": {
    "alwaysAllow": ["ToolSearch"],
    "alwaysAllowBashPatterns": [
      "^cat \"\\$OUTPOST_ENVELOPE\"$",
      "^cat ",
      "^jq "
    ],
    "alwaysAllowMcpPatterns": [
      "^mcp__outpost__"
    ],
    "alwaysAllowPathPatterns": []
  },
  "read": {
    "alwaysAllow": ["Read", "Glob", "Grep", "LS", "NotebookRead"],
    "alwaysAllowBashPatterns": [
      "^(ls|head|tail|file|wc|stat|du|pwd|whoami|date|env|which|type|echo|printf)(\\s|$)",
      "^git (status|log|diff|show|blame|branch|remote -v|config --get|fetch)(\\s|$)",
      "^rg(\\s|$)",
      "^find(\\s|$)"
    ],
    "alwaysAllowMcpPatterns": [],
    "alwaysAllowPathPatterns": []
  },
  "pull": {
    "alwaysAllow": ["WebFetch", "WebSearch", "ListMcpResourcesTool", "ReadMcpResourceTool"],
    "alwaysAllowBashPatterns": [
      "^curl -s ",
      "^curl -fsS http",
      "^gh (pr view|pr list|run view|run list|api|repo view|issue view|issue list|search)(\\s|$)"
    ],
    "alwaysAllowMcpPatterns": [
      "^mcp__claude_ai_Linear__(get_|list_|search_)",
      "^mcp__claude_ai_DataDog_MCP__(search_|analyze_|find_|list_|load_|get_|aggregate_)",
      "^mcp__github__(get|list|search|pull_request_read|issue_read)",
      "^mcp__notion__notion-(fetch|search|get-)",
      "^mcp__claude_ai_Slack__slack_(read_|search_)",
      "^mcp__incident-io__(.*_show|.*_list|alert_stats|incident_stats|follow_up_stats|escalation_stats|ask|ask_incident|ask_telemetry|investigation_sync)$",
      "^mcp__grafana__(get_|list_|search_|query_|find_|analyze_)"
    ],
    "alwaysAllowPathPatterns": []
  },
  "edit": {
    "alwaysAllow": [],
    "alwaysAllowBashPatterns": [
      "^mage(\\s|$)",
      "^npm (test|run|install|ci)(\\s|$)",
      "^go (build|test|vet|run|mod)(\\s|$)",
      "^pytest(\\s|$)",
      "^cargo (build|test|check|clippy)(\\s|$)",
      "^git (rebase|checkout --)(\\s|$)"
    ],
    "alwaysAllowMcpPatterns": [],
    "alwaysAllowPathPatterns": [
      "Edit:^/tmp/",
      "Write:^/tmp/",
      "MultiEdit:^/tmp/"
    ]
  },
  "push": {
    "alwaysAllow": [],
    "alwaysAllowBashPatterns": [
      "^gh (pr comment|pr merge|pr review|pr create|issue create|issue comment)(\\s|$)",
      "^git (push|commit|tag)(\\s|$)"
    ],
    "alwaysAllowMcpPatterns": [
      "^mcp__claude_ai_Linear__(save_|create_)",
      "^mcp__github__(create_|update_|merge_|add_|delete_|push_|fork_|request_)",
      "^mcp__claude_ai_Slack__slack_(send_|schedule_|create_|update_)",
      "^mcp__notion__notion-(create-|update-|move-|duplicate-)"
    ],
    "alwaysAllowPathPatterns": []
  }
}
