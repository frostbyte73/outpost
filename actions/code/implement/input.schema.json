{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "code.implement input",
  "type": "object",
  "required": ["jobId", "stepId", "goal", "workspace", "typePayload"],
  "properties": {
    "jobId": { "type": "string" },
    "stepId": { "type": "string" },
    "goal": { "type": "string" },
    "approach": { "type": "string" },
    "risks": { "type": "string" },
    "workspace": {
      "type": "object",
      "required": ["repoCwd", "branch"],
      "properties": {
        "repoCwd": { "type": "string" },
        "branch": { "type": "string" }
      }
    },
    "previousSteps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "action": { "type": "string" },
          "output": { "type": "string" }
        }
      }
    },
    "typePayload": {
      "type": "object",
      "required": ["round"],
      "properties": {
        "round": { "const": "initial" }
      }
    },
    "job": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "externalRef": {
          "type": "object",
          "properties": { "url": { "type": "string", "format": "uri" } }
        }
      }
    },
    "recentLessons": { "type": "array", "items": { "type": "object" } }
  }
}
