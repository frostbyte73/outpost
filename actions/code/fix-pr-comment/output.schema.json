{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "code.fix-pr-comment output",
  "type": "object",
  "required": ["jobId", "stepId", "editId", "status"],
  "properties": {
    "jobId": { "type": "string" },
    "stepId": { "type": "string" },
    "editId": { "type": "string" },
    "status": { "enum": ["done", "failed"] },
    "failure": { "type": "string", "description": "One-line reason. Required when status === 'failed'." }
  }
}
