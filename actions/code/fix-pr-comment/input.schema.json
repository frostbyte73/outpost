{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "code.fix-pr-comment input",
  "type": "object",
  "required": ["jobId", "stepId", "workspace", "typePayload"],
  "properties": {
    "jobId": { "type": "string" },
    "stepId": { "type": "string" },
    "workspace": {
      "type": "object",
      "required": ["repoCwd", "branch"],
      "properties": {
        "repoCwd": { "type": "string" },
        "branch": { "type": "string" }
      }
    },
    "goal": { "type": "string" },
    "approach": { "type": "string" },
    "typePayload": {
      "type": "object",
      "required": ["editJob"],
      "properties": {
        "editJob": {
          "type": "object",
          "required": ["id", "comment"],
          "properties": {
            "id": { "type": "string" },
            "comment": {
              "type": "object",
              "required": ["id", "author", "body"],
              "properties": {
                "id": { "type": "string" },
                "author": { "type": "string" },
                "body": { "type": "string" },
                "file": { "type": "string" },
                "line": { "type": "integer" },
                "diffHunk": { "type": "string" },
                "createdAt": { "type": "string", "format": "date-time" }
              }
            },
            "userNote": { "type": "string" }
          }
        }
      }
    },
    "recentLessons": { "type": "array", "items": { "type": "object" } }
  }
}
