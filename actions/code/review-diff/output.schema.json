{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "code.review-diff output",
  "type": "object",
  "required": ["summary", "issues"],
  "properties": {
    "summary": { "type": "string" },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "file", "comment"],
        "properties": {
          "severity": { "enum": ["info", "warn", "error"] },
          "file": { "type": "string" },
          "line": { "type": "integer" },
          "comment": { "type": "string" }
        }
      }
    }
  }
}
