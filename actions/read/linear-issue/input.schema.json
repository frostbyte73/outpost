{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "read.linear-issue input",
  "type": "object",
  "required": ["ticket_ref"],
  "properties": {
    "ticket_ref": {
      "type": "string",
      "description": "Linear issue ID (e.g. CSCU-432) or full URL.",
      "minLength": 3
    },
    "include_comments": {
      "type": "boolean",
      "default": true
    }
  },
  "additionalProperties": false
}
