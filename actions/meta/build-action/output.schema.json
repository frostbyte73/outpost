{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "meta.build-action output",
  "type": "object",
  "required": ["actionName", "summary", "skillMdAfter"],
  "properties": {
    "actionName": {
      "type": "string",
      "description": "The action's name. Must match the directory it will live in."
    },
    "summary": {
      "type": "string",
      "description": "One paragraph for the human reviewing the proposal."
    },
    "skillMdAfter": {
      "type": "string",
      "description": "Full new SKILL.md text (frontmatter + body)."
    },
    "allowlistAdds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "value"],
        "properties": {
          "kind": { "enum": ["tool", "bash", "mcp", "path"] },
          "value": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  }
}
