{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "meta.orchestrate output",
  "type": "object",
  "required": ["jobId", "mode", "steps"],
  "properties": {
    "jobId": { "type": "string" },
    "mode": { "enum": ["initial", "replan"] },
    "steps": {
      "type": "array",
      "description": "Ordered step list. Per-step shape varies by `type`; the orchestrator is expected to honor the catalog passed in via input.stepTypeCatalog.",
      "items": {
        "type": "object",
        "required": ["type", "title"],
        "properties": {
          "type": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "goal": { "type": "string" },
          "approach": { "type": "string" },
          "risks": { "type": "string" },
          "action": { "type": "string" },
          "workspace": {
            "type": "object",
            "properties": {
              "kind": { "enum": ["writable", "readonly"] },
              "repoCwd": { "type": "string" },
              "branch": { "type": "string" }
            }
          },
          "forwardOutput": { "type": "boolean" },
          "parallelGroup": { "type": "string" },
          "keepId": { "type": "string" }
        }
      }
    }
  }
}
