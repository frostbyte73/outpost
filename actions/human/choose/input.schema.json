{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "human.choose input",
  "type": "object",
  "required": ["prompt", "options"],
  "properties": {
    "prompt": { "type": "string" },
    "options": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": ["value", "label"],
        "properties": {
          "value": { "type": "string", "description": "Returned when selected. Stable identifier." },
          "label": { "type": "string", "description": "Shown to the user." },
          "description": { "type": "string", "description": "Optional second line under the label." },
          "link": { "type": "string", "format": "uri" },
          "preview": { "description": "Free-form metadata rendered alongside the option (e.g. JSON object, diff snippet)." }
        }
      }
    },
    "multi_select": { "type": "boolean", "default": false },
    "default_value": { "type": "string", "description": "Pre-selected option's value." }
  },
  "additionalProperties": false
}
