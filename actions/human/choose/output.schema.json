{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "human.choose output",
  "type": "object",
  "required": ["selected"],
  "properties": {
    "selected": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ],
      "description": "Single value when multi_select=false; array of values when multi_select=true."
    },
    "note": { "type": "string" }
  },
  "additionalProperties": false
}
